# Kairon — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── News APIs ──────────────────────────────────────────────────────────────
# Free tier: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Free tier: https://gnews.io/
GNEWS_KEY=your_gnews_key_here

# ── Telegram ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Webhook URL — set only in production (leave blank for polling mode)
# BOT_WEBHOOK_URL=https://yourdomain.com/bot
BOT_WEBHOOK_URL=

# Random secret for Telegram webhook verification (generate with: openssl rand -hex 32)
BOT_WEBHOOK_SECRET=

# ── NVIDIA NIM (Synthesizer) ───────────────────────────────────────────────
# Free API key: https://build.nvidia.com/
NIM_API_KEY=your_nvidia_nim_api_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-70b-instruct
NIM_MAX_TOKENS=900

# ── OpenRouter (Analyzer) ───────────────────────────────────────────────────
# Get free API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (Analyzer) ──────────────────────────────────────────────────────
# Disabled - using OpenRouter for faster processing
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b

# ── FastAPI ────────────────────────────────────────────────────────────────
# URL of the Kairon API (used by n8n to call /trigger)
# In Docker Compose, n8n reaches FastAPI at http://kairon-api:8000
KAIRON_API_URL=http://localhost:8000

# Shared secret for the n8n → /trigger endpoint (generate with: openssl rand -hex 16)
N8N_TRIGGER_SECRET=your_n8n_trigger_secret_here

# ── Pipeline tuning ────────────────────────────────────────────────────────
# Max simultaneous OpenRouter LLM calls (sequential to respect AI thinking time)
MAX_CONCURRENT_LLM=1    # SEQUENTIAL: 1 call at a time - AI models need 30-60 seconds to think

# Articles with relevance below this threshold are dropped
RELEVANCE_THRESHOLD=0.1   # Very low threshold for testing (increase to 0.2-0.3 for production)

# Article fetching limits for testing (increase for production)
NEWSAPI_PAGE_SIZE=2      # 2 articles per topic from NewsAPI (increase to 30 for production)
GNEWS_MAX_RESULTS=1      # 1 article per topic from GNews (increase to 10 for production)

# Article scraping limits for testing (increase for production)
HACKER_NEWS_MAX_STORIES=1    # 1 story from Hacker News (increase to 20 for production)
ARS_TECHNICA_MAX_ARTICLES=1  # 1 article from Ars Technica (increase to 15 for production)

# ── Storage ────────────────────────────────────────────────────────────────
STORAGE_DIR=storage

# ── Stage 2 (MemPalace) — uncomment when ready ────────────────────────────
# DATABASE_URL=postgresql://kairon:kairon@localhost:5432/kairon
# MEMPALACE_DIR=~/.mempalace
